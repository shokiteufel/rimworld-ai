<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net472</TargetFramework>
    <RootNamespace>RimWorldBot</RootNamespace>
    <AssemblyName>RimWorldBot</AssemblyName>
    <OutputPath>..\Assemblies\</OutputPath>
    <AppendTargetFrameworkToOutputPath>false</AppendTargetFrameworkToOutputPath>
    <LangVersion>latest</LangVersion>
    <Deterministic>true</Deterministic>
    <Copyright>© 2026 mediainvita</Copyright>
    <Product>RimWorld Bot</Product>
    <Description>Autonome Entscheidungs-KI als RimWorld-Mod (Skeleton — Story 1.1)</Description>
    <!-- Nullable wird in Story 1.3 (BotGameComponent) aktiviert, wenn es sinnvoll wird.
         Jetzt aus weil Krafs.Rimworld.Ref keine Nullable-Annotationen hat → Warning-Kaskaden. -->
  </PropertyGroup>

  <ItemGroup>
    <!-- Lib.Harmony wird erst in Story 1.2 (Harmony-Bootstrap) referenziert. Story 1.1 ist Skeleton-only. -->
    <PackageReference Include="Krafs.Rimworld.Ref" Version="1.6.*" PrivateAssets="all" />
  </ItemGroup>

</Project>
